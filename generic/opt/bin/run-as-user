#!/bin/sh -u


# run as root (or explicitly specified docker --user)
if [ 0 -eq "$PUID" ] || [ 0 -ne "$(id -u)" ]; then
	exec "$@"
fi


# configure normal user
export HOME="$HOME/$PUSER"
(
	# busybox addgroup/adduser syntax (Alpine)
	cut -d: -f3 /etc/group | grep -qx "$PGID" || addgroup -g "$PGID" "$PGROUP"
	cut -d: -f3 /etc/passwd | grep -qx "$PUID" || adduser -D -u "$PUID" -G "$PGROUP" -h "$HOME" "$PUSER"
	mkdir -p "$HOME"
	chown -R "$PUID:$PGID" "$HOME"
) > /dev/null 2>&1

# run as normal user
sudo --user "#$PUID" --group "#$PGID" --non-interactive --preserve-env -- "$@"
